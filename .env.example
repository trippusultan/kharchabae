# ---- KharchaBae config ----
# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# PostgreSQL connection string (Supabase / Neon / Vercel Postgres free tiers).
# The app falls back to seeded data if this is empty/unreachable.
DATABASE_URL="postgresql://user:password@host:5432/kharchabae?schema=public"

# Bright Data — live scraping (optional; seed data used otherwise).
BRIGHTDATA_API_KEY=""
BRIGHTDATA_ZONE=""

# Redis (optional) — enables background refresh queue. Falls back to direct refresh.
REDIS_URL=""

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Razorpay UPI payments (optional; set to enable payments)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
